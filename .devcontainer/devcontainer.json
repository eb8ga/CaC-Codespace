// Config options: https://github.com/rocker-org/devcontainer-templates/tree/main/src/r-ver
{
  "name": "R Workshop - RStudio",
  "image": "ghcr.io/rocker-org/devcontainer/geospatial:4.4",

  // Add software
  "features": {
    // Quarto for R Markdown support: https://github.com/rocker-org/devcontainer-features/blob/main/src/quarto-cli/README.md
    "ghcr.io/rocker-org/devcontainer-features/quarto-cli:1": {
      "installTinyTex": true,
      "version": "latest"
    },
    // RStudio Server: https://github.com/rocker-org/devcontainer-features/blob/main/src/rstudio-server/README.md
    "ghcr.io/rocker-org/devcontainer-features/rstudio-server": {}
  },

  // Install remaining workshop R packages.
  // sf and spatial system libraries are pre-installed in the geospatial image.
  "postCreateCommand": "Rscript install.R",

  // Automatically open RStudio in the browser when the Codespace starts
  "forwardPorts": [8787],
  "portsAttributes": {
    "8787": {
      "label": "RStudio",
      "onAutoForward": "openBrowser"
    }
  },

  "postAttachCommand": {
    "rstudio-start": "rserver"
  }
}
